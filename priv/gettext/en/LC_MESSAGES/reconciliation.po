msgid "callout_how_use_item_1"
msgstr "Select the entity first so the session list and account scope stay inside one ownership boundary."

msgid "callout_how_use_item_2"
msgstr "Create one active session per institution account, then clear postings as you match them against the statement."

msgid "callout_how_use_item_3"
msgstr "Use the difference card as the final checkpoint before you complete the session."

msgid "callout_how_use_title"
msgstr "How to use reconciliation"

msgid "callout_tips_item_1"
msgstr "If a posting was cleared by mistake, un-clear it before the session is completed."

msgid "callout_tips_item_2"
msgstr "Completed sessions remain visible as history, so you can review the final balance and timestamps later."

msgid "callout_tips_title"
msgstr "Tips"

msgid "callout_warning_item_1"
msgstr "A completed reconciliation session is read-only; the UI will not let you clear or un-clear postings after completion."

msgid "callout_warning_item_2"
msgstr "Voiding a transaction with reconciled postings is blocked by the ledger guard."

msgid "callout_warning_title"
msgstr "Warnings"

msgid "callout_what_is_body"
msgstr "Reconciliation is the workflow layer that sits on top of immutable ledger postings and helps you match one account against one statement."

msgid "callout_what_is_item_1"
msgstr "A session stores the statement date and statement balance for one institution account."

msgid "callout_what_is_item_2"
msgstr "Cleared postings are provisional and can still be removed while the session stays active."

msgid "callout_what_is_item_3"
msgstr "Completing the session promotes cleared postings into reconciled history without mutating the original postings."

msgid "callout_what_is_title"
msgstr "What reconciliation is"

