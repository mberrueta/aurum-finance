msgid "callout_how_use_item_1"
msgstr "Select the entity first so every account stays inside the correct ownership boundary."

msgid "callout_how_use_item_2"
msgstr "Use the Institution tab for bank, broker, wallet, credit card, and loan accounts."

msgid "callout_how_use_item_3"
msgstr "Use Category accounts for income and expense classification, even when they may be auto-created later."

msgid "callout_how_use_title"
msgstr "How to use accounts"

msgid "callout_tips_item_1"
msgstr "Keep names specific enough to distinguish real-world accounts, especially when multiple institutions share the same currency."

msgid "callout_tips_item_2"
msgstr "Archive accounts instead of deleting them so historical postings and audits remain consistent."

msgid "callout_tips_title"
msgstr "Tips"

msgid "callout_warning_item_1"
msgstr "Management group, account type, subtype, and currency are part of the canonical account shape and become immutable after creation."

msgid "callout_warning_item_2"
msgstr "System-managed accounts are real ledger accounts; keep them separate from day-to-day operational workflows."

msgid "callout_warning_title"
msgstr "Warnings"

msgid "callout_what_is_body"
msgstr "Accounts are the canonical ledger containers for balances, postings, categories, and technical system flows."

msgid "callout_what_is_item_1"
msgstr "Institution accounts represent operational containers such as bank, broker, wallet, credit, and loan accounts."

msgid "callout_what_is_item_2"
msgstr "Category accounts are still ledger accounts, typically income or expense, managed separately for clarity."

msgid "callout_what_is_item_3"
msgstr "System-managed accounts support technical ledger flows such as opening balances or FX-related mechanics."

msgid "callout_what_is_title"
msgstr "What accounts are"

