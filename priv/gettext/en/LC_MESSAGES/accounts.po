msgid "tooltip_field_account_type"
msgstr "Canonical ledger type used for balance behavior. For institution accounts it is derived automatically from the subtype and becomes immutable after creation."

msgid "tooltip_field_category_type"
msgstr "Choose whether this category account records income or expense activity. These remain real ledger accounts, not labels."

msgid "tooltip_field_currency"
msgstr "Native currency of the account. It defaults from the selected entity country and becomes immutable after creation, so choose the real operating currency."

msgid "tooltip_field_institution"
msgstr "Human-readable institution or platform name, such as Mercury, Fidelity, or Chase. Useful when multiple accounts share the same subtype."

msgid "tooltip_field_institution_account_ref"
msgstr "Non-sensitive account reference, usually the last 4 digits or an internal nickname. Avoid storing full account numbers here."

msgid "tooltip_field_management_group"
msgstr "Controls where the account is managed in the product: Institution, Category, or System-managed. It does not replace ledger semantics."

msgid "tooltip_field_notes"
msgstr "Optional operational context for humans, such as reconciliation guidance or intended usage. Keep secrets and full account numbers out of notes."

msgid "tooltip_field_operational_subtype"
msgstr "Operational shape of the account, such as checking, brokerage cash, or credit card. This drives the derived account type and later workflow behavior."

