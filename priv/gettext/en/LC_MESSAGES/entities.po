#, elixir-autogen, elixir-format
msgid "callout_what_is_body"
msgstr "Each entity is a separate ownership boundary in your finance system."

#: lib/aurum_finance_web/live/entities_live.html.heex:29
#, elixir-autogen, elixir-format
msgid "callout_what_is_item_1"
msgstr "Use one entity for your personal accounts (banks, brokers, cash, cards)."

#: lib/aurum_finance_web/live/entities_live.html.heex:30
#, elixir-autogen, elixir-format
msgid "callout_what_is_item_2"
msgstr "If you manage family/spouse accounts, model them as their own entity boundary."

#: lib/aurum_finance_web/live/entities_live.html.heex:31
#, elixir-autogen, elixir-format
msgid "callout_what_is_item_3"
msgstr "Business/company accounts should live in a separate entity for clean ownership and reporting."

#: lib/aurum_finance_web/live/entities_live.html.heex:111
#, elixir-autogen, elixir-format
