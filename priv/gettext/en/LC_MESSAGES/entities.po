#: lib/aurum_finance_web/live/entities_live.html.heex:114
#, elixir-autogen, elixir-format
msgid "callout_how_use_item_2"
msgstr "Set country and fiscal residency carefully, because tax defaults depend on them."

#: lib/aurum_finance_web/live/entities_live.html.heex:115
#, elixir-autogen, elixir-format
msgid "callout_how_use_item_3"
