# AurumFinance local defaults (safe to commit)

export DIR="${DIR:-$(pwd)}"
export MIX_PORT="${MIX_PORT:-4000}"
export TIDEWAVE_PORT="${TIDEWAVE_PORT:-4001}"
export LIVE_DEBUGGER_PORT="${LIVE_DEBUGGER_PORT:-4002}"
export PORT="${PORT:-${MIX_PORT}}"

export DB_NAME="${DB_NAME:-aurum_finance_dev}"
export DB_HOSTNAME="${DB_HOSTNAME:-localhost}"
export DB_USERNAME="${DB_USERNAME:-postgres}"
export DB_PASSWORD="${DB_PASSWORD:-postgres}"
export DB_PORT="${DB_PORT:-5432}"

export DATABASE_URL="${DATABASE_URL:-ecto://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOSTNAME}:${DB_PORT}/${DB_NAME}}"
export HOST_PROJECT_DIR="${HOST_PROJECT_DIR:-${DIR}}"

[ -f .envrc.custom ] && source .envrc.custom
[ -f .envrc_custom ] && source .envrc_custom
